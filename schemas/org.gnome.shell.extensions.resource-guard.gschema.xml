<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="resource-guard">

  <schema id="org.gnome.shell.extensions.resource-guard"
    path="/org/gnome/shell/extensions/resource-guard/">

    <!-- Combined memory usage threshold in percent (50-100).
         Dialog appears when (RAM used + Swap used) / (RAM total + Swap total) >= this value. -->
    <key name="memory-threshold" type="i">
      <default>90</default>
      <summary>Memory Threshold (%)</summary>
      <description>
        Percentage of combined (RAM + Swap) usage that triggers the warning dialog.
      </description>
      <range min="50" max="100" />
    </key>

    <!-- Polling interval in seconds (1-30). -->
    <key name="check-interval" type="i">
      <default>3</default>
      <summary>Check Interval (seconds)</summary>
      <description>
        How often to sample system statistics, in seconds.
      </description>
      <range min="1" max="30" />
    </key>

    <!-- Cool-down after closing the dialog, in seconds (10-600). -->
    <key name="cooldown-time" type="i">
      <default>60</default>
      <summary>Cool-down Time (seconds)</summary>
      <description>
        Minimum wait time after dismissing a dialog before a new one can appear.
      </description>
      <range min="10" max="600" />
    </key>

    <!-- Show/hide CPU usage in panel. -->
    <key name="show-cpu" type="b">
      <default>true</default>
      <summary>Show CPU Indicator</summary>
      <description>
        Whether to show a CPU usage indicator in the top panel.
      </description>
    </key>

    <!-- Show/hide memory usage in panel. -->
    <key name="show-memory" type="b">
      <default>true</default>
      <summary>Show Memory Indicator</summary>
      <description>
        Whether to show a memory usage indicator in the top panel.
      </description>
    </key>

  </schema>

</schemalist>
